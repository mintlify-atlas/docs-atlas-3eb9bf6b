  "keyFeatures": [
    "Next.js 16 App Router with React Server Components",
    "Tailwind CSS v4 with dark mode support",
    "30+ pre-built dashboard UI components",
    "ApexCharts integration for line and bar charts",
    "FullCalendar integration for calendar page",
    "Responsive sidebar with collapsible navigation",
    "Authentication pages (Sign In / Sign Up)",
    "Ecommerce dashboard with metrics, sales charts, and order tables",
    "Form elements including date picker, multi-select, and switches",
    "World map (jsvectormap) for demographic data visualization",
    "TypeScript-first codebase",
    "MIT licensed and free to use"
  ],
  "publicApiSurface": [
    "Button component (variant: primary | outline, size: sm | md)",
    "Alert component",
    "Badge component",
    "Avatar component",
    "Modal component (useModal hook)",
    "Dropdown component",
    "Table component",
    "Form / Input / Label / Select / MultiSelect components",
    "DatePicker component (flatpickr wrapper)",
    "Switch component",
    "EcommerceMetrics component",
    "MonthlySalesChart component",
    "StatisticsChart component",
    "MonthlyTarget component",
    "RecentOrders component",
    "DemographicCard component (world map)",
    "AppSidebar layout component",
    "AppHeader layout component",
    "SidebarContext / ThemeContext providers",
    "useModal hook",
    "useGoBack hook"
  ]
}
