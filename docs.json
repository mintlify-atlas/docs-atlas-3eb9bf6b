{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TailAdmin",
  "theme": "willow",
  "colors": {
    "primary": "#141c2b",
    "light": "#4257e2",
    "dark": "#9cacec"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/b7bf0b41-34b4-40e9-a402-5c01401df9d0.svg",
    "dark": "https://media.brand.dev/b7bf0b41-34b4-40e9-a402-5c01401df9d0.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/TailAdmin/free-nextjs-admin-dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/TailAdmin/free-nextjs-admin-dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": ["introduction", "getting-started/installation", "getting-started/project-structure"]
          },
          {
            "group": "Configuration",
            "pages": ["getting-started/tailwind-config", "getting-started/dark-mode", "getting-started/customization"]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Layout",
            "pages": ["components/sidebar", "components/header"]
          },
          {
            "group": "UI Elements",
            "pages": ["components/buttons", "components/alerts", "components/badges", "components/avatars", "components/modals", "components/dropdowns"]
          },
          {
            "group": "Forms",
            "pages": ["components/form-elements", "components/date-picker", "components/multi-select"]
          },
          {
            "group": "Data Display",
            "pages": ["components/tables", "components/charts", "components/images", "components/videos"]
          }
        ]
      },
      {
        "tab": "Pages",
        "groups": [
          {
            "group": "Dashboard",
            "pages": ["pages/ecommerce-dashboard"]
          },
          {
            "group": "Authentication",
            "pages": ["pages/signin", "pages/signup"]
          },
          {
            "group": "Other Pages",
            "pages": ["pages/profile", "pages/calendar", "pages/blank-page", "pages/404"]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": ["changelog"]
          }
        ]
      }
    ]
  }
}
